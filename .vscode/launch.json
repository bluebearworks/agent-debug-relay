{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "run extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/out/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
